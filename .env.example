# =============================================================================
# Hinga+ Environment Configuration
# =============================================================================
# This app is fully stateless. No database is required.
# All weather data is fetched live from the Open-Meteo public API (no key needed).
# =============================================================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Hinga+

# Open-Meteo (public API — no key required)
# Base URL used in src/lib/weatherService.ts
NEXT_PUBLIC_OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

